# Required - Gemini API key for embeddings, summarization, and Gemini chat
GEMINI_API_KEY=your-gemini-api-key

# Optional - Anthropic API key for Claude chat provider
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional - Custom data directory (default: ~/.bookrc)
BOOKRC_DB_PATH=

# Google Drive integration (optional)
# Get your folder ID from the Google Drive URL: https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=
